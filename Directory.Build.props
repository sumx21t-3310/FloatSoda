<Project>

    <PropertyGroup>
        <Version>0.2.0</Version>
    </PropertyGroup>

    <PropertyGroup>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    </PropertyGroup>

    <PropertyGroup>
        <Authors>Sumx21t</Authors>
        <Copyright>Copyright (c) 2026 Sumx21t</Copyright>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/sumx21t-3310/FloatSoda</PackageProjectUrl>
        <RepositoryUrl>https://github.com/sumx21t-3310/FloatSoda</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageTags>steamvr;openvr;overlay;vr;ui;skiasharp;declarative-ui</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Roslynator.Analyzers" Version="4.13.1" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <None Include="$(MSBuildThisFileDirectory)README.md" Pack="true" PackagePath="\" Visible="false" />
    </ItemGroup>

</Project>
